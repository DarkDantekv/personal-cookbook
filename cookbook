<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>My Cookbook</title>
<style>
*{box-sizing:border-box;font-family:Georgia,serif}
body{
  margin:0;
  background:#f7f1e8;
  color:#3b2f2f;
}
header{
  padding:40px 30px;
  text-align:center;
  background:linear-gradient(to right,#fffaf0,#f8e8d0);
  border-bottom:2px solid #e7d5b7;
}
header h1{
  font-size:48px;
  margin:0;
}
header p{
  font-size:18px;
  color:#7a6855;
}
.container{
  display:grid;
  grid-template-columns:280px 1fr;
  min-height:100vh;
}
.sidebar{
  background:#fffaf4;
  padding:25px;
  border-right:2px solid #eadcc7;
  position:sticky;
  top:0;
  height:100vh;
  overflow:auto;
}
.sidebar h2{
  margin-top:0;
}
.search{
  width:100%;
  padding:12px;
  border-radius:12px;
  border:1px solid #d6c4a8;
  margin-bottom:20px;
}
.recipe-link{
  display:block;
  padding:12px;
  margin-bottom:10px;
  text-decoration:none;
  color:#5b4636;
  border-radius:12px;
  background:#fdf6ec;
}
.recipe-link:hover{
  background:#f5e8d7;
}
.main{
  padding:30px;
}
.recipe-card{
  background:white;
  border-radius:24px;
  padding:24px;
  margin-bottom:25px;
  box-shadow:0 12px 30px rgba(0,0,0,.08);
}
.recipe-image{
  width:100%;
  height:280px;
  object-fit:cover;
  border-radius:20px;
  margin:15px 0;
}
.recipe-meta{
  display:flex;
  gap:15px;
  flex-wrap:wrap;
  margin:15px 0;
}
.badge{
  background:#fff2d8;
  padding:8px 14px;
  border-radius:999px;
  font-size:14px;
}
.section-title{
  margin-top:20px;
  font-size:22px;
}
ul,ol{
  line-height:1.8;
}
.add-btn{
  width:100%;
  padding:14px;
  border:none;
  border-radius:14px;
  background:#8b5e3c;
  color:white;
  font-weight:bold;
  cursor:pointer;
}
.modal{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.4);
  justify-content:center;
  align-items:center;
}
.modal-content{
  background:white;
  width:min(650px,95%);
  padding:25px;
  border-radius:24px;
}
input,textarea,select{
  width:100%;
  padding:12px;
  margin:8px 0;
  border-radius:12px;
  border:1px solid #ddd;
}
textarea{min-height:100px}
@media(max-width:900px){
  .container{grid-template-columns:1fr}
  .sidebar{position:relative;height:auto}
}
</style>
</head>
<body>
<header>
  <h1>📖 My Storybook Cookbook</h1>
  <p>A beautiful place to save family recipes, favorites, and kitchen experiments.</p>
</header>

<div class="container">
  <aside class="sidebar">
    <h2>Table of Contents</h2>
    <input id="search" class="search" placeholder="Search recipes..." oninput="renderRecipes()" />
    <div id="recipeLinks"></div>
    <button class="add-btn" onclick="openModal()">+ Add Recipe</button>
  </aside>

  <main class="main">
    <div id="recipeContainer"></div>
  </main>
</div>

<div class="modal" id="recipeModal">
  <div class="modal-content">
    <h2>Add New Recipe</h2>
    <input id="recipeTitle" placeholder="Recipe title" />
    <input id="recipeCategory" placeholder="Category (Breakfast, Dinner, Dessert...)" />
    <input id="recipeTime" placeholder="Cook time (ex: 30 mins)" />
    <input id="recipeServings" placeholder="Servings" />
    <input id="recipeImage" placeholder="Image URL" />
    <textarea id="recipeIngredients" placeholder="Ingredients (one per line)"></textarea>
    <textarea id="recipeSteps" placeholder="Steps (one per line)"></textarea>
    <button class="add-btn" onclick="saveRecipe()">Save Recipe</button>
  </div>
</div>

<script>
let recipes = JSON.parse(localStorage.getItem('cookbookRecipes')) || [
  {
    id: Date.now(),
    title:'Grandma\'s Pancakes',
    category:'Breakfast',
    time:'20 mins',
    servings:'4',
    image:'https://images.unsplash.com/photo-1528207776546-365bb710ee93',
    ingredients:['2 cups flour','2 eggs','1 cup milk'],
    steps:['Mix ingredients','Cook on skillet','Serve warm']
  }
];

function saveData(){
  localStorage.setItem('cookbookRecipes', JSON.stringify(recipes));
}

function openModal(){
  document.getElementById('recipeModal').style.display='flex';
}

function closeModal(){
  document.getElementById('recipeModal').style.display='none';
}

function saveRecipe(){
  const recipe={
    id:Date.now(),
    title:document.getElementById('recipeTitle').value,
    category:document.getElementById('recipeCategory').value,
    time:document.getElementById('recipeTime').value,
    servings:document.getElementById('recipeServings').value,
    image:document.getElementById('recipeImage').value,
    ingredients:document.getElementById('recipeIngredients').value.split('\n').filter(Boolean),
    steps:document.getElementById('recipeSteps').value.split('\n').filter(Boolean)
  };

  recipes.push(recipe);
  saveData();
  renderRecipes();
  closeModal();
}

function renderRecipes(){
  const search = document.getElementById('search').value.toLowerCase();
  const recipeContainer = document.getElementById('recipeContainer');
  const recipeLinks = document.getElementById('recipeLinks');

  recipeContainer.innerHTML='';
  recipeLinks.innerHTML='';

  recipes
    .filter(r => r.title.toLowerCase().includes(search) || r.category.toLowerCase().includes(search))
    .forEach(recipe => {
      recipeLinks.innerHTML += `<a href="#recipe-${recipe.id}" class="recipe-link">${recipe.title}</a>`;

      recipeContainer.innerHTML += `
        <div class="recipe-card" id="recipe-${recipe.id}">
          <h2>${recipe.title}</h2>
          <div class="recipe-meta">
            <span class="badge">🍽 ${recipe.category}</span>
            <span class="badge">⏱ ${recipe.time}</span>
            <span class="badge">👨‍👩‍👧 ${recipe.servings} servings</span>
          </div>
          ${recipe.image ? `<img src="${recipe.image}" class="recipe-image" />` : ''}
          <h3 class="section-title">Ingredients</h3>
          <ul>${recipe.ingredients.map(i=>`<li>${i}</li>`).join('')}</ul>
          <h3 class="section-title">Instructions</h3>
          <ol>${recipe.steps.map(s=>`<li>${s}</li>`).join('')}</ol>
        </div>
      `;
    });
}

document.getElementById('recipeModal').addEventListener('click', (e)=>{
  if(e.target.id==='recipeModal') closeModal();
});

renderRecipes();
</script>
</body>
</html>
